classDef node_12_color fill:#f9fbe7,stroke:#827717,stroke-width:3px,color:#000,font-size:12px
class TypeAction node_12_color
classDef node_13_color fill:#fff1f0,stroke:#d32f2f,stroke-width:3px,color:#000,font-size:12px
class Campagne node_13_color
classDef node_14_color fill:#f4e6ff,stroke:#6a1b9a,stroke-width:3px,color:#000,font-size:12px
class Election node_14_color
classDef node_15_color fill:#e6f7ff,stroke:#1890ff,stroke-width:3px,color:#000,font-size:12px
class InstanceElue node_15_color
classDef node_16_color fill:#e8f5e8,stroke:#388e3c,stroke-width:3px,color:#000,font-size:12px
class Segment node_16_color
classDef node_17_color fill:#e0f7fa,stroke:#00838f,stroke-width:3px,color:#000,font-size:12px
class Newsletter node_17_color
classDef node_18_color fill:#fbe9e7,stroke:#bf360c,stroke-width:3px,color:#000,font-size:12px
class Sollicitation node_18_color
